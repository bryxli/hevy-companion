{
  "compilerOptions": {
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": [
    "packages/core/src/**/*",
    "packages/core/test/**/*",
    "packages/functions/src/**/*",
    "packages/functions/test/**/*",
    "packages/frontend/src/**/*",
    "packages/frontend/test/**/*"
  ]
}
